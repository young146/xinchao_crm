{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    },
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/chatbot-widget\\.js",
      "dest": "/chatbot-widget.js"
    },
    {
      "src": "/chatbot-test\\.html",
      "dest": "/chatbot-test.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
